{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "D-Mate",
  "version": "1.1.0",
  "identifier": "com.daonplace.d-mate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "D-Mate",
        "label": "main",
        "width": 960,
        "height": 680,
        "minWidth": 720,
        "minHeight": 520,
        "center": true,
        "visible": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://swork.kr https://api.telegram.org ipc: http://tauri.localhost; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFNUY0MzZGQTU3QTBDMEEKUldRS0RIcWxiME5mSGlraXFZR1hvclVvU0dPckdTOVNFMUlrb05XNHdGTDJvMFZPaUU0UEJLUDgK",
      "endpoints": [
        "https://github.com/dice-book-p/d-mate/releases/latest/download/latest.json"
      ]
    }
  }
}
